# Overton Analyzer Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Overton API Key
# Get one at: https://overton.io/
OVERTON_API_KEY=your_overton_api_key_here

# Optional: Flask Secret Key (for production)
SECRET_KEY=your_secret_key_here

# Optional: Debug Mode (set to False in production)
DEBUG=True
